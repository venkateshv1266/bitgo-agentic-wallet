# ─── BitGo Configuration ───
# Get these from test.bitgo.com:
#   Access Token: Developer Options > Access Tokens (scopes: wallet_create, wallet_spend, wallet_view_all)
#   Enterprise ID: Account Settings > Enterprise Info
BITGO_ACCESS_TOKEN=v2x...your-long-lived-test-token
BITGO_ENV=test
BITGO_EXPRESS_URL=http://localhost:3080
ENTERPRISE_ID=your-enterprise-id

# ─── Passphrase Vault ───
# Encrypts wallet passphrases at rest. Generate with:
#   openssl rand -hex 32
VAULT_MASTER_KEY=your-64-char-hex-key

# ─── Server ───
PORT=3000

# ─── Agent (Claude Code SDK) ───
# Anthropic model used for the agent. Examples: claude-sonnet-4-6, claude-opus-4.
# AGENT_MODEL=claude-sonnet-4-6

# ─── Webhook (optional) ───
# Public URL for BitGo to send transfer confirmation callbacks.
# The start.sh script auto-sets this via cloudflared tunnel.
# If not set, the app uses polling mode (checks every 15s).
# WEBHOOK_URL=https://your-tunnel-url.trycloudflare.com
