{
  "rules": [
    {
      "id": "default-tx-limit",
      "walletId": "*",
      "type": "tx_limit",
      "enabled": true,
      "params": {
        "softLimitUsd": "500",
        "hardLimitUsd": "1000"
      }
    },
    {
      "id": "default-velocity",
      "walletId": "*",
      "type": "velocity_limit",
      "enabled": true,
      "params": {
        "maxTotalUsd": "5000",
        "windowSeconds": 3600
      }
    }
  ]
}
